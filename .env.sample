# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sql_ai_agent

# LLM API — нужен провайдер с endpoint POST /v1/chat/completions (OpenAI-совместимый).
# api.cursor.com НЕ поддерживает chat/completions (будет 404). Используйте OpenAI или OpenRouter.
#
# OpenAI:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_API_KEY=sk-... (https://platform.openai.com/api-keys)
#
# OpenRouter (много моделей, один ключ):
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_API_KEY=sk-or-... (https://openrouter.ai/keys)
#   OPENAI_MODEL=openai/gpt-4o-mini  или  anthropic/claude-3.5-haiku
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: limit to SELECT only (default: true)
AGENT_READ_ONLY=true
